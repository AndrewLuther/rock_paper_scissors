{
  "name": "rock_paper_scissors",
  "version": "1.0.0",
  "description": "Basic rock paper scissors web game",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:game": "esbuild ./src/game.ts --bundle --outfile=./public/js/game.js",
    "build:home": "esbuild ./src/home.ts --bundle --outfile=./public/js/home.js",
    "start:server": "tsx watch server.ts",
    "start": "concurrently 'npm run start:server' 'npm run build:game -- --watch' 'npm run build:home -- --watch'" 

  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewLuther/rock_paper_scissors.git"
  },
  "author": "Andrew Luther",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AndrewLuther/rock_paper_scissors/issues"
  },
  "homepage": "https://github.com/AndrewLuther/rock_paper_scissors#readme",
  "dependencies": {
    "express": "^5.2.1",
    "uuid": "^13.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "nodemon": "^3.1.11",
    "tsx": "^4.21.0"
  }
}
